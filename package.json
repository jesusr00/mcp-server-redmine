{
  "name": "mcp-server-redmine",
  "version": "0.2.2",
  "description": "MCP server for Redmine REST API",
  "type": "module",
  "bin": {
    "mcp-server-redmine": "./dist/index.mjs"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "eslint --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "redmine",
    "model-context-protocol",
    "ai",
    "llm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jesusr00/mcp-server-redmine.git"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.29.2",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^22.15.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-only-warn": "^1.1.0",
    "prettier": "^3.7.4",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0",
    "vitest": "^3.0.0"
  }
}
